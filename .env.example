# Database
DATABASE_URL="postgresql://user:password@localhost:5432/referconnect"

# Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Email delivery (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="ReferConnect <onboarding@resend.dev>"
ADMIN_EMAILS="admin@example.com"

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional public marketing site used by referral redirects.
NEXT_PUBLIC_SITE_URL=""

# Optional webhook and scheduled-job secrets
WEBHOOK_SECRET=""
CRON_SECRET=""

# Optional platform labels used in OTP email templates
PLATFORM_NAME="N45 Referral Program"
PLATFORM_SUPPORT_EMAIL="support@n45portal.com"

# Optional payment integration
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
