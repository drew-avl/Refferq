# Database
DATABASE_URL="postgresql://user:password@localhost:5432/referconnect"

# Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Email delivery (Microsoft Graph)
# MICROSOFT_GRAPH_SENDER must be a real Exchange Online mailbox in the tenant,
# not only an alias, distribution list, or unlicensed address.
MICROSOFT_TENANT_ID="your-tenant-id"
MICROSOFT_CLIENT_ID="your-app-client-id"
MICROSOFT_CLIENT_SECRET="your-app-client-secret"
MICROSOFT_GRAPH_SENDER="notifications@yourdomain.com"
MICROSOFT_GRAPH_SAVE_TO_SENT_ITEMS="false"
ADMIN_EMAILS="admin@example.com"  # Optional extra recipients in addition to active admins/staff

# Text alerts (optional)
SMS_ENABLED="false"
SMS_PROVIDER="voipms" # relay, voipms, 3cx, both, or comma-separated providers such as relay,3cx
ADMIN_SMS_NUMBERS="+15551234567"
SMS_RELAY_URL="" # For Vercel -> fixed-IP VPS relay, for example https://sms-relay.example.com/send-sms
SMS_RELAY_TOKEN=""
SMS_RELAY_TIMEOUT_MS="10000"
REFERRAL_REMINDER_TIME_ZONE="America/New_York"
REFERRAL_REMINDER_BUSINESS_START_HOUR="8"
REFERRAL_REMINDER_BUSINESS_END_HOUR="17"
REFERRAL_REMINDER_DELAY_MINUTES="60"
REFERRAL_REMINDER_BATCH_SIZE="25"
VOIPMS_API_USERNAME=""
VOIPMS_API_PASSWORD=""
VOIPMS_SMS_DID="" # Must be an SMS-capable DID in VoIP.ms
VOIPMS_API_ENDPOINT="https://voip.ms/api/v1/rest.php"
THREECX_SMS_WEBHOOK_URL=""
THREECX_SMS_WEBHOOK_TOKEN=""
THREECX_SMS_FROM=""

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional public marketing site used by referral redirects.
NEXT_PUBLIC_SITE_URL=""

# Optional webhook and scheduled-job secrets
WEBHOOK_SECRET=""
CRON_SECRET=""

# TwentyCRM direct API, schema bootstrap, and durable synchronization
TWENTY_API_BASE_URL="https://api.twenty.com"
TWENTY_API_KEY=""
TWENTY_API_TIMEOUT_MS="12000"
TWENTY_WORKSPACE_ID=""
TWENTY_WORKSPACE_NAME=""
TWENTY_SYNC_MODE="api" # api, workflow (temporary rollback), or off
TWENTY_OUTBOX_BATCH_SIZE="20"
TWENTY_OUTBOX_CONCURRENCY="4"
TWENTY_OUTBOX_MAX_ATTEMPTS="10"
TWENTY_OUTBOUND_WEBHOOK_SECRET="" # Secret from Twenty outbound webhook settings
TWENTY_WEBHOOK_REPLAY_WINDOW_SECONDS="300"
TWENTY_INTEGRATION_ACTOR_ID="" # Optional active admin ID used for inbound audit attribution

# Optional TwentyCRM sync for Referral List, Referral Partners, and Payouts.
# Use TWENTY_WEBHOOK_URL for one shared workflow, or set per-view webhook URLs below.
TWENTY_SYNC_ENABLED="true"
TWENTY_REFERRAL_SYNC_ENABLED="true"
TWENTY_PARTNER_SYNC_ENABLED="true"
TWENTY_PAYOUT_SYNC_ENABLED="true"
TWENTY_WEBHOOK_URL=""
TWENTY_REFERRAL_WEBHOOK_URL=""
TWENTY_PARTNER_WEBHOOK_URL=""
TWENTY_PAYOUT_WEBHOOK_URL=""
TWENTY_WORKFLOW_SIGNING_SECRET="" # Optional signature sent to legacy workflow ingress; Twenty does not validate it
TWENTY_WEBHOOK_TIMEOUT_MS="12000"

# Optional platform labels used in OTP email templates
PLATFORM_NAME="N45 Referral Program"
PLATFORM_SUPPORT_EMAIL="support@n45portal.com"

# Optional payment integration
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
